# ═══════════════════════════════════════════════════════════════
# Neeva AI — .gitignore
# ═══════════════════════════════════════════════════════════════

# ── Node ──────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Build Outputs ─────────────────────────────────────────────
dist/
build/
coverage/

# ── Environment & Secrets ─────────────────────────────────────
# Block ALL .env files by default, then whitelist the safe template
.env
.env.local
.env.*.local
.env.*
!.env.example
!.env.development
!.env.staging
!.env.production

# Credential / key files
*.pem
client_secret_*.json
google-services.json
GoogleService-Info.plist
android/app/google-services.json
ios/NeevaAI/GoogleService-Info.plist

# ── OS Metadata ───────────────────────────────────────────────
.DS_Store
Thumbs.db
._*

# ── IDE / Editor ──────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# ── Deployment / CI ───────────────────────────────────────────
.vercel/
.netlify/

# ── Cache ─────────────────────────────────────────────────────
.cache/
.parcel-cache/
.eslintcache
vite.config.timestamp-*

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
firebase-debug.log

# ── Android / Capacitor ──────────────────────────────────────
android/.gradle/
android/local.properties
*.apk
*.keystore
*.jks

# ── AI Tool Artifacts ─────────────────────────────────────────
.blackbox/
.agents/
.claude/
.kilocode/
.kilo/
skills-lock.json
icon.png

