rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ──────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isParticipant(conversationId) {
      return isAuthenticated()
        && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
    }

    function isRecentTimestamp(requestTime, maxAgeSeconds) {
      return request.time - request.resource.data.updatedAt < duration.value(maxAgeSeconds, 's');
    }

    // ─── Rate limit: max N writes per minute per user ──────────────────

    function rateLimit(maxWrites) {
      let count = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.writeCount;
      return count.isNaN() || count < maxWrites;
    }

    // ─── Users ─────────────────────────────────────────────────────────

    match /users/{userId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isOwner(userId);

      // User's conversation index (lightweight list)
      match /conversations/{conversationId} {
        allow read, write: if isOwner(userId);
      }

      // User's mood entries
      match /moods/{moodId} {
        allow read, write: if isOwner(userId);
      }

      // User's exercise progress
      match /exercises/{exerciseId} {
        allow read, write: if isOwner(userId);
      }

      // User's journey progress document
      match /progress/{progressId} {
        allow read, write: if isOwner(userId)
          && request.resource.data.userId == request.auth.uid;
      }

      // User's daily recommendations
      match /recommendations/{recId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId);
        allow delete: if false;
      }

      // User's streak history (one doc per year)
      match /streaks/{year} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId);
        allow delete: if false;
      }
    }

    // ─── Conversations ─────────────────────────────────────────────────

    match /conversations/{conversationId} {
      allow read: if isParticipant(conversationId);
      allow create: if isAuthenticated();
      allow update: if isParticipant(conversationId);
      allow delete: if isAuthenticated()
        && resource.data.createdBy == request.auth.uid;

      // Messages within a conversation
      match /messages/{messageId} {
        allow read: if isParticipant(conversationId);
        allow create: if isAuthenticated()
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if isAuthenticated()
          && resource.data.senderId == request.auth.uid;
      }

      // Participants within a conversation
      match /participants/{participantId} {
        allow read: if isParticipant(conversationId);
        allow create: if isAuthenticated()
          && (participantId == request.auth.uid
            || get(/databases/$(database)/documents/conversations/$(conversationId)).data.createdBy == request.auth.uid);
        allow update: if isAuthenticated()
          && participantId == request.auth.uid;
        allow delete: if isAuthenticated()
          && get(/databases/$(database)/documents/conversations/$(conversationId)).data.createdBy == request.auth.uid;
      }
    }

    // ─── Programs (reference data, read-only for users) ────────────────

    match /programs/{programId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false; // admins only — seed via script/app

      // Lessons within a program
      match /lessons/{lessonId} {
        allow read: if isAuthenticated();
        allow create, update, delete: if false;
      }
    }

    // ─── Exercises (reference data, read-only for users) ───────────────

    match /exercises/{exerciseId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    // ─── Default Deny ──────────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
