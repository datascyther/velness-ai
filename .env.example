# =============================================================================
# Velness — Environment Configuration Template
# =============================================================================
# Copy this file to create environment-specific configs:
#   cp .env.example .env.development   # local dev (defaults to Firebase emulators)
#   cp .env.example .env.staging       # staging Firebase project
#   cp .env.example .env.production    # production Firebase project
#
# IMPORTANT: Never commit actual secrets. Keep .env*, *.keystore, *.jks in
# .gitignore. The .env file is for your local dev overrides only.
# =============================================================================

# ── App Environment ──────────────────────────────────────────────────────────
# Set to "development", "staging", or "production". App name and behaviour
# change based on this value.
APP_ENV=development

# ── Firebase Configuration (REQUIRED) ────────────────────────────────────────
# Get these from your Firebase Console > Project Settings > General > Your apps
# Alternatively, run: npm run firebase:sync-env
# which reads google-services.json and populates these automatically.
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id

# Set to "true" to connect to local Firebase emulators (development only)
EXPO_PUBLIC_USE_FIREBASE_EMULATORS=false

# Backward-compatible VITE_* keys (for the Vite/web build)
VITE_FIREBASE_API_KEY=${EXPO_PUBLIC_FIREBASE_API_KEY}
VITE_FIREBASE_AUTH_DOMAIN=${EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN}
VITE_FIREBASE_PROJECT_ID=${EXPO_PUBLIC_FIREBASE_PROJECT_ID}
VITE_FIREBASE_STORAGE_BUCKET=${EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET}
VITE_FIREBASE_MESSAGING_SENDER_ID=${EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID}
VITE_FIREBASE_APP_ID=${EXPO_PUBLIC_FIREBASE_APP_ID}
VITE_USE_FIREBASE_EMULATORS=${EXPO_PUBLIC_USE_FIREBASE_EMULATORS}

# ── NVIDIA NIM AI Provider (REQUIRED for AI features) ────────────────────────
# Get your API key from https://build.nvidia.com/
EXPO_PUBLIC_NVIDIA_API_KEY=your_nvidia_api_key_here
EXPO_PUBLIC_NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b
EXPO_PUBLIC_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Backward-compatible VITE_* keys
VITE_NVIDIA_API_KEY=${EXPO_PUBLIC_NVIDIA_API_KEY}
VITE_NVIDIA_MODEL=${EXPO_PUBLIC_NVIDIA_MODEL}
VITE_NVIDIA_BASE_URL=${EXPO_PUBLIC_NVIDIA_BASE_URL}

# SERVER-ONLY NVIDIA key (edge function api/ai/chat.ts). NOT public/client-exposed.
# The edge runtime reads process.env.NVIDIA_API_KEY so LLM + search keys stay server-side.
NVIDIA_API_KEY=your_nvidia_api_key_here

# Client routing flag: true (default) → chat goes through the server-side AI
# Runtime (api/ai/chat). false → call NVIDIA directly (offline/dev only).
VITE_USE_EDGE_RUNTIME=true

# ── API Base URL ─────────────────────────────────────────────────────────────
# Base URL for the server-side AI Runtime edge function (api/ai/chat).
# Empty → web resolves to '/api' (served by `npm run dev` / Vercel). On native
# (Expo) it defaults to http://<dev-machine-ip>:5173/api. When unreachable the
# app transparently falls back to calling NVIDIA directly (see src/services/ai).
# Example: http://192.168.1.100:5173
EXPO_PUBLIC_API_BASE_URL=
VITE_API_BASE_URL=${EXPO_PUBLIC_API_BASE_URL}

# ── EAS Build ────────────────────────────────────────────────────────────────
# Find this in Expo Application Services (EAS) dashboard
# https://expo.dev/accounts/<account>/projects/velness
EAS_PROJECT_ID=

# ── Sentry (optional) ────────────────────────────────────────────────────────
# https://sentry.io/organizations/<org>/projects/velness/
# EXPO_PUBLIC_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>

# ── Supabase Configuration (REQUIRED for backend) ────────────────────────────
# Single Supabase project (ref "whjdjxtbyoojrwvbearg", region ap-northeast-1/Tokyo).
# Dev uses a "develop" branch when branching is available; until then dev reuses prod.
# Get URL + anon key from: Supabase Dashboard > Project Settings > API.
#   - EXPO_PUBLIC_SUPABASE_URL        : project REST/Auth base URL (public).
#   - EXPO_PUBLIC_SUPABASE_ANON_KEY   : anon key — PUBLIC, safe to ship to clients
#                                       (RLS still enforces all access control).
#   - EXPO_PUBLIC_SUPABASE_PROJECT_ID : the project ref above (public).
# The anon key is PUBLIC (safe to ship to clients; RLS enforces access).
# The service_role key is SECRET — keep it out of these client env files.
#   Store it only in: Supabase project secrets, or a server-only .env (gitignored).
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
EXPO_PUBLIC_SUPABASE_PROJECT_ID=your_supabase_project_id_here

# Backward-compatible VITE_* keys (for the Vite/web build)
VITE_SUPABASE_URL=${EXPO_PUBLIC_SUPABASE_URL}
VITE_SUPABASE_ANON_KEY=${EXPO_PUBLIC_SUPABASE_ANON_KEY}
VITE_SUPABASE_PROJECT_ID=${EXPO_PUBLIC_SUPABASE_PROJECT_ID}

# Google OAuth (Supabase Auth provider). Referenced by supabase/config.toml
# as env(SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID/SECRET). Supabase loads these
# from the project root .env (.env.example -> your local .env).
# Create a Web OAuth client in Google Cloud Console and set its authorized
# redirect URI to: https://<EXPO_PUBLIC_SUPABASE_PROJECT_ID>.supabase.co/auth/v1/callback
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=your_google_web_client_id_here
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=your_google_web_client_secret_here

# SERVER-ONLY (do NOT commit; do NOT prefix with EXPO_PUBLIC_/VITE_).
# Place the service_role key here in your local .env (which is gitignored),
# or set it as a Supabase project secret for Edge Functions / server code.
# SUPABASE_PROD_SERVICE_ROLE_KEY=your_service_role_key_here

# ── AI Runtime: Live Search Providers (server-only, optional) ────────────────
# Free providers (Wikipedia, Open-Meteo, Google News RSS) need NO keys.
# Premium semantic search is enabled automatically once a key is present.
# EXA_API_KEY=your_exa_api_key_here            # primary premium search
# TAVILY_API_KEY=your_tavily_api_key_here      # fallback web search

# ── AI Runtime: Feature Flags (server-side, all default true unless noted) ───
# Toggle capabilities independently without redeploys.
# ENABLE_KNOWLEDGE=true
# ENABLE_NEWS=true
# ENABLE_WEATHER=true
# ENABLE_MEDICAL=true
# ENABLE_MEMORY=true
# ENABLE_CITATIONS=true
# ENABLE_RAG=false                              # Phase 4 (pgvector) — off until freeze lifts

# ── AI Runtime: Model Gateway resilience (server-side) ──────────────────────
# Per-request timeout for the NVIDIA streaming call (ms). Requests that exceed
# this are aborted and degrade to a single graceful error chunk rather than a
# hard 500. Default 30000 (30s) when unset.
# MODEL_TIMEOUT_MS=30000

# ── AI Runtime: Phase 6 memory persistence (Pinecone) ───────────────────────
# Long-term personal memory is mirrored to a dedicated per-uid namespace on the
# existing Pinecone index (velness-rag, serverless). No Supabase change needed.
# Namespace convention: mem-<uid>  (e.g. mem-user_abc123). This is derived
# automatically by PineconeMemoryStore; you do NOT set MEMORY_NAMESPACE manually.
# Requires PINECONE_API_KEY (above) + NVIDIA embeddings (VITE_NVIDIA_BASE_URL) to
# be configured. When either is absent, memory degrades to in-memory only.
# PINECONE_INDEX=velness-rag
# PINECONE_CLOUD=aws
# PINECONE_REGION=us-east-1
