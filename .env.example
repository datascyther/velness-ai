# =============================================================================
# Neeva AI — Environment Configuration Template
# =============================================================================
# Copy this file to create environment-specific configs:
#   cp .env.example .env.development   # local dev (defaults to Firebase emulators)
#   cp .env.example .env.staging       # staging Firebase project
#   cp .env.example .env.production    # production Firebase project
#
# IMPORTANT: Never commit actual secrets. Keep .env*, *.keystore, *.jks in
# .gitignore. The .env file is for your local dev overrides only.
# =============================================================================

# ── App Environment ──────────────────────────────────────────────────────────
# Set to "development", "staging", or "production". App name and behaviour
# change based on this value.
APP_ENV=development

# ── Firebase Configuration (REQUIRED) ────────────────────────────────────────
# Get these from your Firebase Console > Project Settings > General > Your apps
# Alternatively, run: npm run firebase:sync-env
# which reads google-services.json and populates these automatically.
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id

# Set to "true" to connect to local Firebase emulators (development only)
EXPO_PUBLIC_USE_FIREBASE_EMULATORS=false

# Backward-compatible VITE_* keys (for the Vite/web build)
VITE_FIREBASE_API_KEY=${EXPO_PUBLIC_FIREBASE_API_KEY}
VITE_FIREBASE_AUTH_DOMAIN=${EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN}
VITE_FIREBASE_PROJECT_ID=${EXPO_PUBLIC_FIREBASE_PROJECT_ID}
VITE_FIREBASE_STORAGE_BUCKET=${EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET}
VITE_FIREBASE_MESSAGING_SENDER_ID=${EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID}
VITE_FIREBASE_APP_ID=${EXPO_PUBLIC_FIREBASE_APP_ID}
VITE_USE_FIREBASE_EMULATORS=${EXPO_PUBLIC_USE_FIREBASE_EMULATORS}

# ── NVIDIA NIM AI Provider (REQUIRED for AI features) ────────────────────────
# Get your API key from https://build.nvidia.com/
EXPO_PUBLIC_NVIDIA_API_KEY=your_nvidia_api_key_here
EXPO_PUBLIC_NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b
EXPO_PUBLIC_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Backward-compatible VITE_* keys
VITE_NVIDIA_API_KEY=${EXPO_PUBLIC_NVIDIA_API_KEY}
VITE_NVIDIA_MODEL=${EXPO_PUBLIC_NVIDIA_MODEL}
VITE_NVIDIA_BASE_URL=${EXPO_PUBLIC_NVIDIA_BASE_URL}

# ── API Base URL ─────────────────────────────────────────────────────────────
# Used for web/Vite dev server. Mobile uses direct NVIDIA calls by default.
# Example: http://192.168.1.100:5173
EXPO_PUBLIC_API_BASE_URL=
VITE_API_BASE_URL=${EXPO_PUBLIC_API_BASE_URL}

# ── EAS Build ────────────────────────────────────────────────────────────────
# Find this in Expo Application Services (EAS) dashboard
# https://expo.dev/accounts/<account>/projects/neeva-ai
EAS_PROJECT_ID=

# ── Sentry (optional) ────────────────────────────────────────────────────────
# https://sentry.io/organizations/<org>/projects/neeva-ai/
# EXPO_PUBLIC_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
